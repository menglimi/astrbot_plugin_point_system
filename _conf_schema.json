{
  "points_name": {
    "description": "积分自定义名称",
    "type": "string",
    "hint": "你可以将“积分”改为“金币”、“贡献度”或“欧气值”等。",
    "default": "积分"
  },
  "sign_in_trigger": {
    "description": "无前缀签到完整触发词（兼容旧配置）",
    "type": "string",
    "hint": "旧版兼容项。若已配置签到触发关键词，则会同时支持“关键词+签到”和“签到+关键词”。",
    "default": "星缘签到"
  },
  "sign_in_trigger_keyword": {
    "description": "无前缀签到触发关键词",
    "type": "string",
    "hint": "例如填“群名简称”后，用户可直接发送“关键词+签到”或“签到+关键词”进行签到。",
    "default": "星缘"
  },
  "lottery_trigger_keyword": {
    "description": "无前缀抽奖触发关键词",
    "type": "string",
    "hint": "例如填“群名简称”后，用户可直接发送“关键词+抽奖”或“抽奖+关键词”参与默认模式抽奖。",
    "default": "星缘"
  },
  "sign_in_settings": {
    "description": "签到功能设置",
    "type": "object",
    "items": {
      "sign_in_mode": {
        "description": "签到积分模式",
        "type": "string",
        "hint": "random 为随机积分，fixed 为固定积分。",
        "default": "random"
      },
      "fixed_sign_in_points": {
        "description": "固定签到积分",
        "type": "int",
        "hint": "当签到积分模式为 fixed 时，每日签到固定获得多少积分。",
        "default": 20
      },
      "min_sign_in_points": {
        "description": "签到获得积分下限",
        "type": "int",
        "hint": "每日签到随机获得的最小积分数额。",
        "default": 10
      },
      "max_sign_in_points": {
        "description": "签到获得积分上限",
        "type": "int",
        "hint": "每日签到随机获得的最大积分数额。",
        "default": 30
      },
      "first_sign_in_bonus": {
        "description": "首次签到奖励",
        "type": "int",
        "hint": "用户第一次签到时额外获得的积分。",
        "default": 20
      },
      "daily_first_sign_in_bonus": {
        "description": "每日首签奖励",
        "type": "int",
        "hint": "每天第一个完成签到的用户可额外获得的积分，签到日于每日 04:00 刷新。",
        "default": 0
      },
      "fortune_event_enabled": {
        "description": "是否开启签到稀有彩蛋",
        "type": "bool",
        "hint": "开启后，签到时会有极低概率触发欧皇或非酋事件。",
        "default": true
      },
      "fortune_event_chance": {
        "description": "签到稀有彩蛋概率",
        "type": "float",
        "hint": "默认 0.002，表示 0.2% 概率触发欧皇/非酋事件。",
        "default": 0.002
      },
      "fortune_event_points": {
        "description": "签到稀有彩蛋积分变化",
        "type": "int",
        "hint": "触发欧皇时加分，触发非酋时扣分，默认 300。",
        "default": 300
      },
      "fortune_pity_enabled": {
        "description": "是否开启签到彩蛋保底",
        "type": "bool",
        "hint": "开启后，欧皇和非酋会分别按独立计数触发保底。",
        "default": true
      },
      "fortune_lucky_pity_threshold": {
        "description": "欧皇保底次数",
        "type": "int",
        "hint": "连续多少次签到未触发欧皇后保底触发一次，默认 100；填 0 表示关闭欧皇保底。",
        "default": 100
      },
      "fortune_unlucky_pity_threshold": {
        "description": "非酋保底次数",
        "type": "int",
        "hint": "连续多少次签到未触发非酋后保底触发一次，默认 100；填 0 表示关闭非酋保底。",
        "default": 100
      },
      "streak_bonus_enabled": {
        "description": "是否开启连续签到奖励",
        "type": "bool",
        "hint": "开启后，连续签到会按天数获得额外加成。",
        "default": true
      },
      "streak_step_bonus": {
        "description": "连续签到每日加成",
        "type": "int",
        "hint": "从连续签到第 2 天开始，每多一天增加多少积分。",
        "default": 2
      },
      "streak_bonus_cap": {
        "description": "连续签到加成上限",
        "type": "int",
        "hint": "连续签到额外加成的最大值，避免数值膨胀。",
        "default": 20
      },
      "weekly_streak_bonus": {
        "description": "连续 7 天奖励",
        "type": "int",
        "hint": "每逢连续签到第 7、14、21... 天时额外获得的奖励。",
        "default": 15
      }
    }
  },
  "activity_settings": {
    "description": "群聊活跃奖励设置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否开启活跃奖励",
        "type": "bool",
        "hint": "开启后，用户发送合规群消息时可静默获得积分。",
        "default": true
      },
      "points_per_message": {
        "description": "每次活跃奖励积分",
        "type": "int",
        "hint": "每次满足条件的群消息可获得多少积分。",
        "default": 1
      },
      "cooldown_seconds": {
        "description": "活跃奖励冷却时间",
        "type": "int",
        "hint": "同一用户两次活跃奖励之间至少间隔多少秒。",
        "default": 300
      },
      "daily_limit": {
        "description": "每日活跃奖励上限次数",
        "type": "int",
        "hint": "单个用户每天最多通过活跃消息获取多少次积分。",
        "default": 6
      },
      "min_text_length": {
        "description": "活跃消息最短长度",
        "type": "int",
        "hint": "消息纯文本少于该长度时，不计入活跃奖励。",
        "default": 4
      }
    }
  },
  "birthday_settings": {
    "description": "生日功能设置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否开启生日功能",
        "type": "bool",
        "hint": "关闭后将停用生日签到、生日奖励和定时寿星播报。",
        "default": true
      },
      "sign_in_trigger": {
        "description": "生日签到触发词",
        "type": "string",
        "hint": "用户发送该文本时触发生日签到，例如“生日签到”。",
        "default": "生日签到"
      },
      "reward_points": {
        "description": "生日签到奖励积分",
        "type": "int",
        "hint": "生日签到成功时奖励多少积分。",
        "default": 50
      },
      "auto_record_when_unset": {
        "description": "未记录生日时自动记录今天",
        "type": "bool",
        "hint": "开启后，用户首次使用生日签到时，会自动把当天记为生日。",
        "default": true
      },
      "auto_broadcast_enabled": {
        "description": "是否开启生日名单播报",
        "type": "bool",
        "hint": "开启后，插件会在设定时间自动检查并播报当日寿星名单。",
        "default": true
      },
      "auto_broadcast_time": {
        "description": "生日名单播报时间",
        "type": "string",
        "hint": "按 24 小时制填写，例如 08:00 或 20:30。",
        "default": "08:00"
      }
    }
  },
  "lottery_settings": {
    "description": "积分抽奖设置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否开启积分抽奖",
        "type": "bool",
        "hint": "开启后，用户可通过 /抽奖 消耗积分参与抽奖。",
        "default": true
      },
      "default_mode": {
        "description": "默认抽奖模式",
        "type": "string",
        "hint": "支持 personal 或 group；用户直接发送 /抽奖 时会使用这里的模式。",
        "default": "personal"
      },
      "personal_enabled": {
        "description": "是否开启个人抽奖",
        "type": "bool",
        "hint": "相当于个人抽奖功能开关。",
        "default": true
      },
      "group_enabled": {
        "description": "是否开启群体抽奖",
        "type": "bool",
        "hint": "相当于群体抽奖功能开关。",
        "default": true
      },
      "personal_cost": {
        "description": "个人抽奖消耗积分",
        "type": "int",
        "hint": "每次个人抽奖消耗多少积分。",
        "default": 20
      },
      "personal_daily_limit": {
        "description": "个人抽奖每日次数",
        "type": "int",
        "hint": "每个用户每天最多可进行多少次个人抽奖。",
        "default": 1
      },
      "personal_prizes": {
        "description": "个人抽奖奖项设置",
        "type": "object",
        "items": {
          "fifth": {
            "description": "五等奖",
            "type": "object",
            "items": {
              "label": {
                "description": "奖项名称",
                "type": "string",
                "default": "五等奖"
              },
              "min_points": {
                "description": "奖励积分下限",
                "type": "int",
                "default": 0
              },
              "max_points": {
                "description": "奖励积分上限",
                "type": "int",
                "default": 5
              },
              "weight": {
                "description": "奖项权重",
                "type": "float",
                "hint": "按概率占比填写，例如 40 表示 40%。",
                "default": 40
              }
            }
          },
          "fourth": {
            "description": "四等奖",
            "type": "object",
            "items": {
              "label": {
                "description": "奖项名称",
                "type": "string",
                "default": "四等奖"
              },
              "min_points": {
                "description": "奖励积分下限",
                "type": "int",
                "default": 6
              },
              "max_points": {
                "description": "奖励积分上限",
                "type": "int",
                "default": 15
              },
              "weight": {
                "description": "奖项权重",
                "type": "float",
                "default": 30
              }
            }
          },
          "third": {
            "description": "三等奖",
            "type": "object",
            "items": {
              "label": {
                "description": "奖项名称",
                "type": "string",
                "default": "三等奖"
              },
              "min_points": {
                "description": "奖励积分下限",
                "type": "int",
                "default": 16
              },
              "max_points": {
                "description": "奖励积分上限",
                "type": "int",
                "default": 25
              },
              "weight": {
                "description": "奖项权重",
                "type": "float",
                "default": 20
              }
            }
          },
          "second": {
            "description": "二等奖",
            "type": "object",
            "items": {
              "label": {
                "description": "奖项名称",
                "type": "string",
                "default": "二等奖"
              },
              "min_points": {
                "description": "奖励积分下限",
                "type": "int",
                "default": 26
              },
              "max_points": {
                "description": "奖励积分上限",
                "type": "int",
                "default": 40
              },
              "weight": {
                "description": "奖项权重",
                "type": "float",
                "default": 9.7
              }
            }
          },
          "first": {
            "description": "一等奖",
            "type": "object",
            "items": {
              "label": {
                "description": "奖项名称",
                "type": "string",
                "default": "一等奖"
              },
              "min_points": {
                "description": "奖励积分下限",
                "type": "int",
                "default": 100
              },
              "max_points": {
                "description": "奖励积分上限",
                "type": "int",
                "default": 100
              },
              "weight": {
                "description": "奖项权重",
                "type": "float",
                "default": 0.3
              }
            }
          }
        }
      },
      "group_cost": {
        "description": "群体抽奖报名消耗积分",
        "type": "int",
        "hint": "每位用户参加一次群体抽奖需要消耗的积分。",
        "default": 20
      },
      "group_daily_limit_per_user": {
        "description": "群体抽奖每人每日次数",
        "type": "int",
        "hint": "每个用户每天最多可参加几次群体抽奖。",
        "default": 1
      },
      "group_required_participants": {
        "description": "群体抽奖开奖人数",
        "type": "int",
        "hint": "群体抽奖达到该人数后立即开奖。",
        "default": 5
      },
      "group_distribution_ratios": {
        "description": "群体抽奖分配比例",
        "type": "list",
        "hint": "按参与人数顺序对应的分配比例，例如 1,9,20,25,35。比例会自动归一化后分配奖池。",
        "default": [1, 9, 20, 25, 35]
      }
    }
  },
  "special_date_reward_entries": {
    "description": "日期口令奖励词条",
    "type": "template_list",
    "hint": "参考世界书词条形式配置。满足日期和关键词后，用户发送消息即可获得指定积分。",
    "templates": {
      "default": {
        "name": "活动奖励词条",
        "items": {
          "name": {
            "description": "词条名称",
            "type": "string",
            "hint": "用于区分不同的活动奖励。",
            "default": "节日奖励"
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          },
          "priority": {
            "description": "优先级",
            "type": "int",
            "hint": "同一条消息命中多条词条时，优先级越小越先判定。",
            "default": 50
          },
          "scope": {
            "description": "生效范围",
            "type": "list",
            "hint": "可填写群号、QQ号，或使用 group:群号 / user:QQ号；留空表示不限制。",
            "default": []
          },
          "dates": {
            "description": "生效日期",
            "type": "list",
            "hint": "支持 YYYY-MM-DD、MM-DD 或 M-D，例如 2026-04-04 或 04-04。",
            "default": ["04-04"]
          },
          "keywords": {
            "description": "触发词",
            "type": "list",
            "hint": "支持正则表达式；开启精确匹配后则按完整文本匹配。",
            "default": ["清明安康"]
          },
          "exact_match": {
            "description": "是否精确匹配",
            "type": "bool",
            "hint": "开启后，消息内容必须与触发词完全一致。",
            "default": true
          },
          "reward_points": {
            "description": "奖励积分",
            "type": "int",
            "default": 20
          },
          "daily_limit_per_user": {
            "description": "每人每日触发次数",
            "type": "int",
            "hint": "通常保持 1 即可，避免重复刷取。",
            "default": 1
          },
          "probability": {
            "description": "触发概率",
            "type": "float",
            "hint": "1 表示必定触发，小于 1 表示按概率触发。",
            "default": 1.0
          },
          "announce": {
            "description": "是否发送提示消息",
            "type": "bool",
            "hint": "关闭后只发放积分，不额外回复。",
            "default": true
          },
          "reply_template": {
            "description": "提示模板",
            "type": "string",
            "hint": "支持 {user}、{entry}、{points}、{name}、{total}、{date}。",
            "default": "{user}触发活动词条【{entry}】，获得 {points} {name}。\n当前共有 {total} {name}。"
          }
        }
      }
    }
  },
  "backup_settings": {
    "description": "自动备份设置",
    "type": "object",
    "items": {
      "enabled": {
        "description": "是否开启自动备份",
        "type": "bool",
        "hint": "开启后，插件会在设定时间自动备份积分数据文件。",
        "default": false
      },
      "backup_paths": {
        "description": "备份地址列表",
        "type": "list",
        "hint": "可填写目录或文件路径。填写目录时会自动生成带时间戳的备份文件；可同时配置多个地址。",
        "default": []
      },
      "auto_backup_time": {
        "description": "自动备份时间",
        "type": "string",
        "hint": "按 24 小时制填写，例如 03:00 或 23:30。",
        "default": "03:00"
      }
    }
  },
  "negative_settings": {
    "description": "负分提示设置",
    "type": "object",
    "items": {
      "debt_message": {
        "description": "负分状态提示文案",
        "type": "string",
        "hint": "用户在负分状态下尝试抽奖时显示的提示文案。",
        "default": "你已背负债务，请穿上女仆装打工。"
      }
    }
  },
  "leaderboard_settings": {
    "description": "排行榜设置",
    "type": "object",
    "items": {
      "display_limit": {
        "description": "排行榜显示人数",
        "type": "int",
        "hint": "执行 /积分榜 时展示的用户数量。",
        "default": 10
      },
      "show_self_rank": {
        "description": "是否在榜单下方显示自己的排名",
        "type": "bool",
        "hint": "如果开启，用户在查看排行榜时能看到自己当前的位次。",
        "default": true
      }
    }
  },
  "message_templates": {
    "description": "自定义回复消息模板",
    "type": "object",
    "hint": "可使用 {user}、{points}、{name}、{total}、{streak}、{total_sign_in_days}、{sign_in_status}、{bonus_detail} 等变量。",
    "items": {
      "sign_in_success": {
        "description": "签到成功提示",
        "type": "string",
        "default": "{user}签到成功，获得 {points} {name}{bonus_detail}。\n当前共有 {total} {name}，连续签到 {streak} 天，累计签到 {total_sign_in_days} 天。",
        "hint": "支持变量：{user}, {points}, {name}, {total}, {streak}, {total_sign_in_days}, {bonus_detail}"
      },
      "already_signed_in": {
        "description": "重复签到提示",
        "type": "string",
        "default": "{user}今天已经签到过啦。\n当前共有 {total} {name}，连续签到 {streak} 天，累计签到 {total_sign_in_days} 天。",
        "hint": "支持变量：{user}, {total}, {name}, {streak}, {total_sign_in_days}"
      },
      "query_points": {
        "description": "积分查询提示",
        "type": "string",
        "default": "{user}当前拥有 {total} {name}。\n连续签到 {streak} 天，累计签到 {total_sign_in_days} 天，今日状态：{sign_in_status}。",
        "hint": "支持变量：{user}, {total}, {name}, {streak}, {total_sign_in_days}, {sign_in_status}"
      }
    }
  },
  "admin_settings": {
    "description": "管理相关设置",
    "type": "object",
    "items": {
      "log_operations": {
        "description": "记录管理员操作日志",
        "type": "bool",
        "hint": "是否在后台日志中记录管理员加减积分的行为。",
        "default": true
      },
      "max_admin_give": {
        "description": "单次手动增减积分上限",
        "type": "int",
        "hint": "限制管理员单次使用指令赠送或扣除的最大分值，防止误操作。",
        "default": 1000
      },
      "points_admin_ids": {
        "description": "积分管理员 QQ 列表",
        "type": "list",
        "hint": "只有这里配置的 QQ 号可以使用 /给积分 和 /扣积分，例如填写 123456789。",
        "default": []
      }
    }
  },
  "exchange_settings": {
    "description": "积分兑换功能设置",
    "type": "object",
    "items": {
      "title_enabled": {
        "description": "是否开启兑换头衔",
        "type": "bool",
        "hint": "开启后，用户可通过 /兑换头衔 消耗积分为自己设置群头衔。",
        "default": true
      },
      "title_cost": {
        "description": "兑换头衔消耗积分",
        "type": "int",
        "hint": "每次兑换群头衔需要消耗的积分数量。",
        "default": 200
      },
      "title_max_length": {
        "description": "头衔最大长度",
        "type": "int",
